import express from "express";
import { createServer } from "http";
import { Server } from "socket.io";
import { GoogleGenerativeAI } from "@google/generative-ai";
import dotenv from "dotenv";
import fs from "fs/promises";
import path from "path";
import { exec } from "child_process";
import util from "util";

const execAsync = util.promisify(exec);

dotenv.config();

const app = express();
const httpServer = createServer(app);
const io = new Server(httpServer);

const genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY);

const systemInstruction = `You are "shesher", an AI operating system living inside a browser.
You will receive ACTIVE TOOLS, CURRENT HTML STATE, and a USER COMMAND.
Respond ONLY with pure, valid JavaScript code. NO markdown fences.

CRITICAL RULE:
If the user asks you to build or modify an app, you MUST use the global OS kernel method:
shesh.buildWorkspaceProject('projectName_no_spaces', { 'index.html': '...', 'app.js': '...', 'style.css': '...' });

IMPORTANT:
1. You must provide the exact filenames as the keys in the object.
2. You are responsible for linking your files together natively inside your index.html (e.g., <link rel="stylesheet" href="style.css"> and <script src="app.js"></script>). Use standard relative paths.
3. If modifying an existing project, you must provide the code for ALL files in the object to avoid deleting them.`;

const model = genAI.getGenerativeModel({
  model: "gemini-2.5-pro",
  systemInstruction,
});
let chatSession = model.startChat({ history: [] });

// The Architect's Tool-Builder Model (Separate from the main conversational agent)
const toolBuilderModel = genAI.getGenerativeModel({
  model: "gemini-2.5-pro",
  systemInstruction: `You are "The Architect", a master JavaScript developer. 
Your job is to write single, reusable, global JavaScript functions based on a description.
Return ONLY the raw JavaScript code. Do not wrap it in markdown. 
The function should be attached to the window object (e.g., window.myTool = function() {...}).`,
});

app.use(express.static("public"));
app.use("/workspaces", express.static("workspaces"));

io.on("connection", async (socket) => {
  console.log("[+] Browser connected to The Architect.");
  // Read the persistent ID from the frontend, fallback to socket.id just in case
  const sessionId = socket.handshake.query.sessionId || socket.id;
  console.log(`[+] Browser connected. Assigning workspace: ${sessionId}`);

  // Create the isolated workspace
  const workspacePath = path.join(process.cwd(), "workspaces", sessionId);
  const clientToolsPath = path.join(workspacePath, "client-tools");
  const serverToolsPath = path.join(workspacePath, "server-tools");

  await fs.mkdir(clientToolsPath, { recursive: true });
  await fs.mkdir(serverToolsPath, { recursive: true });

  // --- UPGRADED: AUTO-DISCOVERY ---
  // KEEP THIS ONE
  socket.on("getArchitectTools", async (callback) => {
    try {
      const clientFiles = await fs.readdir(clientToolsPath).catch(() => []);
      const serverFiles = await fs.readdir(serverToolsPath).catch(() => []);

      callback({
        success: true,
        clientTools: clientFiles
          .filter((f) => f.endsWith(".js"))
          .map((f) => `/workspaces/${sessionId}/client-tools/${f}`),
        serverTools: serverFiles.map((f) => {
          const type = f.endsWith(".js") ? "node" : "bash";
          const name = f.replace(/\.(js|sh)$/, "");
          return { name, type };
        }),
      });
    } catch (error) {
      callback({ success: false, error: error.message });
    }
  });

  socket.on("prompt", async (payload, callback) => {
    const { command, dom, tools } = payload;

    const enrichedPrompt = `--- ACTIVE TOOLS ---\n${tools}\n\n--- CURRENT HTML STATE ---\n${
      dom || "(Empty Container)"
    }\n\n--- USER COMMAND ---\n${command}`;

    console.log(`\n[?] Command received: "${command}"`);

    try {
      const result = await chatSession.sendMessage(enrichedPrompt);
      let jsCode = result.response.text();

      jsCode = jsCode.replace(/^```(javascript|js)?\n/i, "");
      jsCode = jsCode.replace(/\n```$/i, "");

      // SERVER ACKNOWLEDGEMENT: Print a snippet of the generated code
      console.log(`[!] Shesher generated ${jsCode.length} bytes of code.`);
      console.log(
        `[>] Preview: ${jsCode.substring(0, 150).replace(/\n/g, " ")}...`
      );

      callback({ success: true, code: jsCode });
    } catch (error) {
      console.error("[-] Error querying Gemini:", error);
      callback({ success: false, error: error.message });
    }
  });

  socket.on("reset", (callback) => {
    console.log("\n[!] Resetting Shesher memory...");
    chatSession = model.startChat({ history: [] });
    callback({ success: true, message: "Server memory wiped." });
  });

  // --- NEW: DELETE SERVER TOOL ---
  socket.on("deleteServerTool", async ({ name, type }, callback) => {
    try {
      const extension = type === "node" ? ".js" : ".sh";
      const filePath = path.join(serverToolsPath, `${name}${extension}`);
      await fs.unlink(filePath);
      console.log(`[The Architect] Deleted server tool: ${name}`);
      callback({ success: true });
    } catch (error) {
      callback({ success: false, error: error.message });
    }
  });
  // --- UPGRADED CLIENT TOOL FORGER ---
  socket.on("buildTool", async ({ name, description }, callback) => {
    console.log(
      `\n[The Architect] Forging client tool: ${name} for session ${sessionId}...`
    );
    try {
      const prompt = `Write a global JavaScript function named window.${name}. 
                    Description: ${description}
                    Return ONLY pure JavaScript code. NO markdown fences.`;

      const result = await toolBuilderModel.generateContent(prompt);
      let jsCode = result.response
        .text()
        .replace(/^```(javascript|js)?\n/i, "")
        .replace(/\n```$/i, "");

      const filePath = path.join(clientToolsPath, `${name}.js`);
      await fs.writeFile(filePath, jsCode, "utf8");

      // Return the path mapped to the static Express route
      callback({
        success: true,
        path: `/workspaces/${sessionId}/client-tools/${name}.js`,
      });
    } catch (error) {
      callback({ success: false, error: error.message });
    }
  });

  // --- NEW: SERVER TOOL FORGER ---
  socket.on(
    "buildServerTool",
    async ({ name, description, type }, callback) => {
      console.log(
        `\n[The Architect] Forging SERVER tool (${type}): ${name}...`
      );
      try {
        let prompt, extension, code;

        if (type === "node") {
          prompt = `Write a Node.js ES Module that exports a default asynchronous function.
                        It will receive a single 'args' object. 
                        Description: ${description}
                        Return ONLY valid JavaScript. NO markdown fences.
                        Format exactly like: export default async function(args) { ... }`;
          extension = ".js";
        } else if (type === "bash") {
          prompt = `Write a Bash script. 
                        Description: ${description}
                        Return ONLY valid Bash code. NO markdown fences.
                        Start with #!/bin/bash.`;
          extension = ".sh";
        }

        const result = await toolBuilderModel.generateContent(prompt);
        code = result.response
          .text()
          .replace(/^```(javascript|js|bash|sh)?\n/i, "")
          .replace(/\n```$/i, "");

        const filePath = path.join(serverToolsPath, `${name}${extension}`);
        await fs.writeFile(filePath, code, "utf8");

        // Make bash scripts executable
        if (type === "bash") await execAsync(`chmod +x "${filePath}"`);

        console.log(
          `[The Architect] Server tool '${name}' saved to workspace.`
        );
        callback({ success: true });
      } catch (error) {
        callback({ success: false, error: error.message });
      }
    }
  );

  // --- NEW: SERVER TOOL INVOKER ---
  socket.on("invokeServerTool", async ({ name, type, args }, callback) => {
    console.log(`\n[The Architect] Invoking SERVER tool: ${name}...`);
    try {
      const extension = type === "node" ? ".js" : ".sh";
      const absolutePath = path.join(serverToolsPath, `${name}${extension}`);
      let output;

      if (type === "node") {
        // Dynamically import the forged ES module.
        // We add a cache-busting query string so Node reads the newest version if it was overwritten!
        const moduleUrl = `file://${absolutePath}?t=${Date.now()}`;
        const { default: handler } = await import(moduleUrl);
        output = await handler(args);
      } else if (type === "bash") {
        // Execute the bash script and pass args as environment variables
        const { stdout, stderr } = await execAsync(`"${absolutePath}"`, {
          env: { ...process.env, ...args },
        });
        if (stderr && !stdout) throw new Error(stderr);
        output = stdout;
      }

      callback({ success: true, result: output });
    } catch (error) {
      console.error("[The Architect] Execution failed:", error);
      callback({ success: false, error: error.message });
    }
  });

  socket.on("disconnect", () => {
    console.log(`[-] Browser disconnected: ${sessionId}`);
    // Optional: Clean up workspace on disconnect, or leave it for persistence
  });
});

const PORT = 3000;
httpServer.listen(PORT, () => {
  console.log(`[!] The Architect is listening at http://localhost:${PORT}`);
});
